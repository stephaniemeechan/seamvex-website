# Local dev — pnpm dev sets NODE_ENV=development (SQLite, local PDFs, password login if no Google, legacy /sign if no Documenso)

# Admin login (password fallback when GOOGLE_CLIENT_ID is not configured — development only)
ADMIN_EMAIL=s.meechan@seamvex.com,j.cyprus@seamvex.com
ADMIN_PASSWORD=

# Session signing (required in production; also encrypts stored OAuth refresh tokens)
SESSION_SECRET=

# Database — omit for SQLite (data/proposals.db); set for Postgres local/Cloud SQL
# DATABASE_URL=postgresql://seamvex:seamvex@localhost:5432/seamvex_crm

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Gmail OAuth callback (optional; defaults to /api/gmail/connect/callback)
GMAIL_REDIRECT_URI=http://localhost:3000/api/gmail/connect/callback

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Xero OAuth — https://developer.xero.com/app/manage
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3000/api/xero/callback
XERO_SALES_ACCOUNT_CODE=200

# Documenso CE — separate service (API v2 paths; see lib/documenso/client.ts)
DOCUMENSO_API_URL=http://localhost:3001/api/v2
DOCUMENSO_API_KEY=
DOCUMENSO_WEBHOOK_SECRET=

# GCS for signed PDFs (optional locally — uses data/pdfs/)
GCS_BUCKET=

# Twilio voice (company line — routing configured in Admin → Settings)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
